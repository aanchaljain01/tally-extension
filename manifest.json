{
  "manifest_version": 3,
  "name": "Tally",
  "version": "1.0.0",
  "description": "Automatically track your job applications across LinkedIn, Handshake, Indeed, and external sites.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.indeed.com/*",
    "https://indeed.com/*",
    "https://joinhandshake.com/*",
    "https://app.joinhandshake.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": [
        "src/content-shared.js",
        "src/content-linkedin.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.indeed.com/*",
        "https://indeed.com/*"
      ],
      "js": [
        "src/content-shared.js",
        "src/content-indeed.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://joinhandshake.com/*",
        "https://app.joinhandshake.com/*"
      ],
      "js": [
        "src/content-shared.js",
        "src/content-handshake.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://*/*"
      ],
      "exclude_matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://www.indeed.com/*",
        "https://indeed.com/*",
        "https://joinhandshake.com/*",
        "https://app.joinhandshake.com/*"
      ],
      "js": [
        "src/content-shared.js",
        "src/content-external.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Tally"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}